{
    "version": 3,
    "configurePresets": [
        {
            "name": "mingw64",
            "displayName": "MinGW64 Release",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build",
            "toolchainFile": "${sourceDir}/cmake/toolchain-mingw64.cmake",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "mingw64",
            "configurePreset": "mingw64"
        }
    ]
}
