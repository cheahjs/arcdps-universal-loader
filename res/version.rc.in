#include <winver.h>

VS_VERSION_INFO VERSIONINFO
FILEVERSION    @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
PRODUCTVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
FILEFLAGSMASK  VS_FFI_FILEFLAGSMASK
FILEFLAGS      0
FILEOS         VOS_NT_WINDOWS32
FILETYPE       VFT_DLL
FILESUBTYPE    VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName",      "arcdps-universal-loader"
            VALUE "FileDescription",  "arcdps Universal Loader"
            VALUE "FileVersion",      "@PROJECT_VERSION@"
            VALUE "InternalName",     "arcdps_universal_loader"
            VALUE "OriginalFilename", "@OUTPUT_NAME@.dll"
            VALUE "ProductName",      "arcdps Universal Loader"
            VALUE "ProductVersion",   "@PROJECT_VERSION@"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 1200
    END
END
